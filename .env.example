# App
NODE_ENV=production
APP_URL=http://localhost:3000

# Database (MySQL)
DATABASE_URL=mysql://ekspedisi:ekspedisi_secret@db:3306/ekspedisi_online

# JWT / Session
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_EMAIL_VERIFICATION_SECRET=change-me-email-verification-secret

# Midtrans Payment
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# Cloudflare Turnstile (Captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# SMTP Email (opsional, untuk verifikasi email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Ekspedisi Online <noreply@example.com>
