# ============================================================
# APPLICATION
# ============================================================

# Digunakan saat aplikasi dijalankan langsung dari VS Code.
# Docker Compose akan menimpa nilai ini menjadi:
# - Lokal Docker: http://localhost:8080
# - VM1 UKK:      http://IP_VM1:8080
APP_URL=http://localhost:3000


# ============================================================
# DATABASE MYSQL
# ============================================================

# Koneksi untuk development lokal.
# Sesuaikan username dan password MySQL pada komputer masing-masing.
#
# Jika akun root tidak memiliki password:
# DATABASE_URL=mysql://root:@127.0.0.1:3306/ekspedisi_aja
#
# Jika akun root memiliki password:
# DATABASE_URL=mysql://root:your-local-mysql-password@127.0.0.1:3306/ekspedisi_aja

DATABASE_URL=mysql://root:@127.0.0.1:3306/ekspedisi_aja

# Di dalam Docker, docker-compose.yml akan menimpanya menjadi:
# mysql://ekspedisi:ekspedisi_secret@database:3306/ekspedisi_aja


# ============================================================
# JWT / SESSION
# ============================================================

JWT_ACCESS_SECRET=replace-with-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-random-refresh-secret-min-32-chars
JWT_EMAIL_VERIFICATION_SECRET=replace-with-random-email-verification-secret


# ============================================================
# GOOGLE RECAPTCHA
# ============================================================

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key


# ============================================================
# MIDTRANS PAYMENT
# ============================================================

MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false


# ============================================================
# SMTP EMAIL / MAILTRAP
# ============================================================

SMTP_HOST=live.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password
MAILTRAP_FROM="DRG Ekspedisi <noreply@example.com>"